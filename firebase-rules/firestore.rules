rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data ──────────────────────────────────────────────────
    // Auth check uses request.auth != null (Firebase anonymous auth session
    // created via clerkFirebaseBridge.js after Clerk sign-in).
    // Data paths use Clerk user.id as the userId segment.

    // Works
    match /users/{userId}/works/{workId} {
      allow read, write: if request.auth != null;
    }

    // Deleted works
    match /users/{userId}/deletedWorks/{workId} {
      allow read, write: if request.auth != null;
    }

    // Workspaces
    match /users/{userId}/workspaces/{wsId} {
      allow read, write: if request.auth != null;
    }

    // Expense Tracker
    match /users/{userId}/accounts/{accountId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/transactions/{txnId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/categories/{catId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/budgets/{budgetId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/bills/{billId} {
      allow read, write: if request.auth != null;
    }

    // Leaderboard
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Friend requests
    match /friendRequests/{reqId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null;
    }

    // Friends list
    match /friends/{userId}/list/{friendId} {
      allow read, write: if request.auth != null;
    }

    // Private chats (chat metadata)
    match /privateChats/{chatId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null;
    }

    // Private chat messages
    match /privateChats/{chatId}/messages/{msgId} {
      allow read, write: if request.auth != null;
    }
  }
}
